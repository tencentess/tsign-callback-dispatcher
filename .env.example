# ──── Storage Backend ────
# Config store type: "file" (default, local filesystem) or "k8s" (K8s ConfigMap API)
CONFIG_STORE=file
# Base directory for file-based config (only used when CONFIG_STORE=file)
# CONFIG_DIR=/path/to/config

# ──── K8s ConfigMap (only used when CONFIG_STORE=k8s) ────
# K8S_NAMESPACE=default
# K8S_CONFIGMAP_NAME=tsign-dispatcher-config
# K8S_API_SERVER=https://kubernetes.default.svc

# ──── Authentication ────
# JWT secret key (MUST change in production!)
JWT_SECRET=your-strong-random-secret-here
# JWT token expiration time
JWT_EXPIRES_IN=24h
# Default admin password (only used on first startup if no users exist)
ADMIN_DEFAULT_PASSWORD=admin123

# ──── CORS ────
# Comma-separated allowed origins (leave empty to allow all in development)
CORS_ORIGINS=

# ──── Logging ────
LOG_LEVEL=info
NODE_ENV=production
