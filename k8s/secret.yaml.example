apiVersion: v1
kind: Secret
metadata:
  name: tsign-dispatcher-secret
  namespace: default
  labels:
    app: tsign-dispatcher
type: Opaque
# IMPORTANT: Replace placeholder values with your actual secrets before applying!
# Generate base64-encoded values:
#   echo -n "your-strong-jwt-secret-here" | base64
#   echo -n "your-admin-password-here" | base64
stringData:
  JWT_SECRET: "<REPLACE_WITH_STRONG_SECRET>"
  ADMIN_DEFAULT_PASSWORD: "<REPLACE_WITH_STRONG_PASSWORD>"
